# Maintainer: Demigirlboss
# PKGBUILD for FFmpeg Studio

pkgname=ffmpeg-studio
pkgver=1.0.0
pkgrel=1
pkgdesc="A simple desktop interface for FFmpeg operations"
arch=('x86_64')
url="https://github.com/Demigirlboss/ffmpeg-studio"
license=('MIT')
depends=('ffmpeg' 'gtk3')
optdepends=()
provides=()
conflicts=()

source=("https://github.com/Demigirlboss0/ffmpeg-studio/releases/download/v1.0.0/ffmpeg-studio"
        "https://github.com/Demigirlboss0/ffmpeg-studio/releases/download/v1.0.0/icon.png")
sha256sums=('SKIP' 'SKIP')

package() {
  install -Dm755 "${srcdir}/ffmpeg-studio" "${pkgdir}/usr/bin/ffmpeg-studio"
  
  mkdir -p "${pkgdir}/usr/share/applications"
  cat > "${pkgdir}/usr/share/applications/ffmpeg-studio.desktop" << EOF
[Desktop Entry]
Name=FFmpeg Studio
Comment=A simple desktop interface for FFmpeg operations
Exec=ffmpeg-studio
Icon=ffmpeg-studio
Terminal=false
Type=Application
Categories=AudioVideo;VideoEncoder;
EOF

  mkdir -p "${pkgdir}/usr/share/icons/hicolor/128x128/apps"
  mkdir -p "${pkgdir}/usr/share/icons/hicolor/256x256/apps"
  mkdir -p "${pkgdir}/usr/share/icons/hicolor/512x512/apps"
  
  install -Dm644 "${srcdir}/icon.png" "${pkgdir}/usr/share/icons/hicolor/128x128/apps/ffmpeg-studio.png"
  install -Dm644 "${srcdir}/icon.png" "${pkgdir}/usr/share/icons/hicolor/256x256/apps/ffmpeg-studio.png"
  install -Dm644 "${srcdir}/icon.png" "${pkgdir}/usr/share/icons/hicolor/512x512/apps/ffmpeg-studio.png"
  install -Dm644 "${srcdir}/icon.png" "${pkgdir}/usr/share/pixmaps/ffmpeg-studio.png"
}
